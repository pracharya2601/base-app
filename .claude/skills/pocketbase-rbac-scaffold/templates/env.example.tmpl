# ──────────────────────────────────────────────────────────────────────────
# Secrets template. Copy to `.env` (gitignored) and fill in real values:
#     cp .env.example .env
#
# PRODUCTION: do NOT ship a .env file. Inject these SAME variable names from
# your platform's secret store (AWS Secrets Manager / SSM Parameter Store,
# Kubernetes Secret, Fly.io secrets, Render/Railway env, Docker swarm secrets).
# The container only reads them from the environment — it doesn't care how
# they got there.
# ──────────────────────────────────────────────────────────────────────────

# --- Litestream → S3 backup target ------------------------------------------
# Leave LITESTREAM_BUCKET empty to run with NO replication (pure local dev).
LITESTREAM_BUCKET=

LITESTREAM_REGION=us-east-1

# Real AWS S3:        leave ENDPOINT empty and FORCE_PATH_STYLE=false.
# S3-compatible       (Cloudflare R2, Backblaze B2, MinIO, etc.):
#                     set the endpoint URL and FORCE_PATH_STYLE=true.
LITESTREAM_ENDPOINT=
LITESTREAM_FORCE_PATH_STYLE=false

LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
